{
  "manifest_version": 3,
  "name": "OpenStroid Boosteroid Capture",
  "description": "Captures Boosteroid auth/session evidence from a real Chrome session for local OpenStroid development.",
  "version": "0.1.0",
  "permissions": ["cookies", "storage", "webRequest", "tabs"],
  "host_permissions": [
    "https://boosteroid.com/*",
    "https://*.boosteroid.com/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OpenStroid Capture",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boosteroid.com/*",
        "https://*.boosteroid.com/*"
      ],
      "js": ["page-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://boosteroid.com/*",
        "https://*.boosteroid.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": [
        "https://boosteroid.com/*",
        "https://*.boosteroid.com/*"
      ]
    }
  ]
}
